<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20.0" prefWidth="550.0" prefHeight="500.0" style="-fx-background-color: #f5f5f5;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.myhomelib.ui.controller.AdvancedSearchController">
    <padding>
        <Insets top="25.0" right="25.0" bottom="25.0" left="25.0"/>
    </padding>
    <children>
        <Label text="Розширені фільтри пошуку" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;"/>

        <GridPane hgap="15.0" vgap="15.0" VBox.vgrow="ALWAYS">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="120.0" prefWidth="130.0" />
                <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" />
            </columnConstraints>

            <children>
                <Label text="Назва книги:" GridPane.rowIndex="0"/>
                <TextField fx:id="titleField" promptText="Введіть частину назви..." GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="Автор:" GridPane.rowIndex="1"/>
                <TextField fx:id="authorField" promptText="Ім'я або прізвище..." GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Серія:" GridPane.rowIndex="2"/>
                <TextField fx:id="seriesField" promptText="Назва серії..." GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                <Label text="Мова:" GridPane.rowIndex="3"/>
                <ComboBox fx:id="languageBox" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                <Label text="Жанр:" GridPane.rowIndex="4"/>
                <TextField fx:id="genreField" promptText="Наприклад: Фантастика" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                <Label text="Оцінка (мін):" GridPane.rowIndex="5"/>
                <Slider fx:id="minRateSlider" max="5" showTickLabels="true" showTickMarks="true" majorTickUnit="1" snapToTicks="true" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                <Label text="Дата додавання (з):" GridPane.rowIndex="6"/>
                <DatePicker fx:id="dateFromPicker" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
            </children>
        </GridPane>

        <HBox alignment="CENTER_RIGHT" spacing="15.0">
            <children>
                <Button fx:id="btnSearch" text="Запустити пошук" onAction="#handleSearch" prefWidth="150.0"
                        style="-fx-background-color: #005088; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                <Button fx:id="btnReset" text="Скинути" onAction="#handleReset" prefWidth="100.0"/>
            </children>
        </HBox>
    </children>
</VBox>