<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.myhomelib.ui.controller.BookEditController" prefWidth="450.0" prefHeight="350.0">
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>
    <children>
        <GridPane hgap="10.0" vgap="12.0" VBox.vgrow="ALWAYS">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="300.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <Label text="Назва книги:" />
                <TextField fx:id="titleField" GridPane.columnIndex="1" />

                <Label text="Серія:" GridPane.rowIndex="1" />
                <TextField fx:id="seriesField" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Номер у серії:" GridPane.rowIndex="2" />
                <TextField fx:id="sequenceNumberField" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label text="Мова:" GridPane.rowIndex="3" />
                <ComboBox fx:id="languageBox" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <Label text="Оцінка (0-5):" GridPane.rowIndex="4" />
                <Spinner fx:id="rateSpinner" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                <Label text="Прогрес (%):" GridPane.rowIndex="5" />
                <Slider fx:id="progressSlider" showTickLabels="true" showTickMarks="true" majorTickUnit="25.0" blockIncrement="5.0" GridPane.columnIndex="1" GridPane.rowIndex="5" />
            </children>
        </GridPane>
        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <children>
                <Button fx:id="btnSave" text="Зберегти" onAction="#handleSaveAction" prefWidth="100.0" style="-fx-font-weight: bold;" />
                <Button fx:id="btnCancel" text="Скасувати" onAction="#handleCancelAction" prefWidth="100.0" />
            </children>
        </HBox>
    </children>
</VBox>