<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="450.0" prefWidth="500.0" spacing="15.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.myhomelib.ui.controller.SearchPresetsController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #111;" text="Збережені пресети пошуку" />
        <Label style="-fx-font-size: 13px; -fx-text-fill: #666;" text="Виберіть шаблон фільтрації для миттєвого застосування:" />

        <ListView fx:id="presetsListView" VBox.vgrow="ALWAYS" />

        <HBox alignment="CENTER_RIGHT" spacing="12.0">
            <children>
                <Button fx:id="btnApply" disable="true" onAction="#handleApplyPreset" prefWidth="130.0" style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-font-weight: bold;" text="Застосувати" />
                <Button fx:id="btnDelete" disable="true" onAction="#handleDeletePreset" prefWidth="100.0" style="-fx-background-color: #c62828; -fx-text-fill: white;" text="Видалити" />
                <Button fx:id="btnCancel" onAction="#handleCancel" prefWidth="90.0" text="Скасувати" />
            </children>
        </HBox>
    </children>
</VBox>